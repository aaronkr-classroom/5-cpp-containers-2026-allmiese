#include <iostream>
#include <iomanip> // setw()

using namespace std;

int get_length(int num) {
    // Base case: 0
    int length = 1;
    while (num / 10 > 0) {
        num /= 10;
        ++ length;
    }
    return length;
}

int main(void) {
    const max_num = 1000;

    int max_len = get_length(max_num);
    int max_sq = get_length(max_num * max_num);

    for (int i = 1; i <= max_num; i++) {
        cout << 
            setw(max_len) << i << ": " <<
            setw(max_sq + 1) << i * i << endl;
    }
    return 0;
}